# Django core settings
DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=True  # True|False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Database settings (MySQL example)
DB_NAME=tajo_db
